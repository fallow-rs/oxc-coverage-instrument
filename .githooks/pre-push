#!/usr/bin/env bash
# Pre-push hook — mirrors the CI checks that block merges to main.
#
# Why: several releases this repo has shipped regressed in CI — or worse,
# tagged a release — because a pre-flight check was skipped locally. The
# costs of a tag-then-fix cycle on a published npm package are high
# (deprecate, bump, repeat). This hook closes that gap.
#
# Setup (one-time, per clone):
#   git config core.hooksPath .githooks
#
# Bypass (use sparingly — e.g. pushing a WIP branch for early CI signal):
#   SKIP_PRE_PUSH=1 git push
#
# Opt-in extras:
#   RUN_TESTS=1 git push       # also run `cargo test --workspace` (~5-10s)

set -euo pipefail

if [ "${SKIP_PRE_PUSH:-0}" = "1" ]; then
  echo "[pre-push] SKIP_PRE_PUSH=1 — skipping all checks"
  exit 0
fi

# Skip on "delete remote branch" pushes (no commits being added).
while read -r local_ref local_sha remote_ref remote_sha; do
  zero="0000000000000000000000000000000000000000"
  if [ "$local_sha" = "$zero" ]; then
    # Deletion push — nothing to validate.
    exit 0
  fi
done

cd "$(git rev-parse --show-toplevel)"

echo "[pre-push] cargo fmt --check"
cargo fmt --all --check

echo "[pre-push] cargo clippy --workspace -- -D warnings"
cargo clippy --workspace --all-targets -- -D warnings

echo "[pre-push] typos ."
if ! command -v typos >/dev/null 2>&1; then
  echo "  typos not installed — install with: cargo install typos-cli"
  echo "  skipping this check"
else
  typos .
fi

if [ "${RUN_TESTS:-0}" = "1" ]; then
  echo "[pre-push] cargo test --workspace"
  cargo test --workspace
fi

echo "[pre-push] OK — pushing."
