{
  "name": "oxc-coverage-instrument",
  "version": "0.3.0",
  "description": "Istanbul-compatible JavaScript/TypeScript coverage instrumentation using the Oxc AST. 8-48x faster than istanbul-lib-instrument.",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./vitest": {
      "types": "./vitest.d.ts",
      "default": "./vitest.js"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "vitest.js",
    "vitest.d.ts"
  ],
  "keywords": [
    "oxc",
    "istanbul",
    "coverage",
    "javascript",
    "typescript",
    "instrumentation",
    "code-coverage"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fallow-rs/oxc-coverage-instrument.git",
    "directory": "napi"
  },
  "homepage": "https://github.com/fallow-rs/oxc-coverage-instrument",
  "bugs": "https://github.com/fallow-rs/oxc-coverage-instrument/issues",
  "napi": {
    "binaryName": "coverage-instrument",
    "packageName": "@oxc-coverage-instrument/binding",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc"
    ]
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.0"
  },
  "scripts": {
    "build": "napi build --release --platform",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi prepublish -t npm",
    "artifacts": "napi artifacts",
    "test": "node test.mjs"
  },
  "optionalDependencies": {
    "@oxc-coverage-instrument/binding-darwin-arm64": "0.3.0",
    "@oxc-coverage-instrument/binding-darwin-x64": "0.3.0",
    "@oxc-coverage-instrument/binding-linux-x64-gnu": "0.3.0",
    "@oxc-coverage-instrument/binding-linux-arm64-gnu": "0.3.0",
    "@oxc-coverage-instrument/binding-linux-x64-musl": "0.3.0",
    "@oxc-coverage-instrument/binding-win32-x64-msvc": "0.3.0",
    "@oxc-coverage-instrument/binding-win32-arm64-msvc": "0.3.0"
  }
}
